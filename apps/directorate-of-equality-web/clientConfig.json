          "reportEmployeeRoleId": { "type": "string", "format": "uuid" },
          "roleTitle": { "type": "string" },
          "base": {
            "$ref": "#/components/schemas/ReportSalaryResultSnapshotDto"
          },
          "full": {
            "$ref": "#/components/schemas/ReportSalaryResultSnapshotDto"
          }
        },
        "required": [

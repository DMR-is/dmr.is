    "/api/v1/reports": {
      "get": {
        "operationId": "listReports",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": { "default": 1, "example": 1, "type": "number" }
          },
          {
            "name": "pageSize",
            "required": false,
            "in": "query",
            "schema": { "default": 10, "example": 10, "type": "number" }
          },
          {
            "name": "type",
            "required": false,
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/components/schemas/ReportTypeEnum" }
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/components/schemas/ReportStatusEnum" }
            }
          },
          {
            "name": "reviewerUserId",
            "required": false,
            "in": "query",
            "schema": {
              "type": "array",
              "items": { "type": "string", "format": "uuid" }
            }
          },
          {
            "name": "unassignedReviewer",
            "required": false,
            "in": "query",
            "description": "When true, returns only reports with no reviewer assigned. Overrides `reviewerUserId` if both are set.",
            "schema": { "type": "boolean" }
          },
          {
            "name": "createdFrom",
            "required": false,
            "in": "query",
            "schema": {
              "format": "date-time",
              "example": "2026-02-19T10:30:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "createdTo",
            "required": false,
            "in": "query",
            "schema": {
              "format": "date-time",
              "example": "2026-02-19T10:30:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "approvedFrom",
            "required": false,
            "in": "query",
            "schema": {
              "format": "date-time",
              "example": "2026-02-19T10:30:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "approvedTo",
            "required": false,
            "in": "query",
            "schema": {
              "format": "date-time",
              "example": "2026-02-19T10:30:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "validUntilFrom",
            "required": false,
            "in": "query",
            "schema": {
              "format": "date-time",
              "example": "2026-02-19T10:30:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "validUntilTo",
            "required": false,
            "in": "query",
            "schema": {
              "format": "date-time",
              "example": "2026-02-19T10:30:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "correctionDeadlineFrom",
            "required": false,
            "in": "query",
            "schema": {
              "format": "date-time",
              "example": "2026-02-19T10:30:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "correctionDeadlineTo",
            "required": false,
            "in": "query",
            "schema": {
              "format": "date-time",
              "example": "2026-02-19T10:30:00.000Z",
              "type": "string"
            }
          },
          {
            "name": "q",
            "required": false,
            "in": "query",
            "description": "Free-text search across company name, kennitala, report identifier, contact name, and contact email. Case-insensitive partial match.",
            "schema": { "type": "string" }
          },
          {
            "name": "sortBy",
            "required": false,
            "in": "query",
            "schema": { "$ref": "#/components/schemas/ReportSortByEnum" }
          },
          {
            "name": "direction",
            "required": false,
            "in": "query",
            "schema": { "$ref": "#/components/schemas/SortDirectionEnum" }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetReportsResponseDto"
                }
              }
            }
          }
        },
        "security": [{ "bearer": [] }],
        "summary": "",
        "tags": ["Reports"]
      }
    },
